# Copy this file to .env.local and fill it in.

# --- Database ---
# DEFAULT: local SQLite (zero signup, instant). A file appears at ./local.db
DATABASE_URL="file:./local.db"

# PRODUCTION: Neon Postgres. To "make it real", swap the two lines above for the
# line below (and change provider/dialect in lib/auth.ts + drizzle.config.ts).
# See README "Make it real: swap SQLite -> Neon".
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Auth (BetterAuth) ---
# Generate a real one with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-me-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"

# Public base URL the browser auth client calls (same origin in dev).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
